
locals {
  firewalls = {
    "fw1" = {
      address = "192.168.101.1"
      network = "192.168.101.0/24"
    }
    "fw2" = {
      address = "192.168.102.1"
      network = "192.168.102.0/24"
    }
    "fw3" = {
      address = "192.168.103.1"
      network = "192.168.103.0/24"
    }
  }
}

data "smc_href" "suite_b_gcm_128" {
  name = "vpn_profile/Suite-B-GCM-128"
}

data "smc_href" "log_server" {
  type  = "log_server"
  name = "*"
}

data "smc_href" "internal_gateway" {
  for_each = local.firewalls
  name = format("%s#%s",
  smc_single_fw.tf_single_fw[each.key].lk.internal_gateway, "tf_single_fw*")
}


resource "smc_single_fw" "tf_single_fw" {
  for_each       = local.firewalls
  name           = "tf_single_${each.key}"
  log_server_ref = data.smc_href.log_server.href

  nodes {
    firewall_node {
      name   = "node ${each.key}"
      nodeid = 1
    }
  }

  physical_interfaces {
    physical_interface {
      interface_id = 0
      interfaces {
        single_node_interface {
          nodeid        = 1
          nicid         = 0
          address       = each.value.address
          network_value = each.value.network
          primary_mgt   = true
        }
      }
    }
  }
}

resource "smc_vpn" "tf_sample_vpn" {
  mobile_vpn_topology_mode = "None"
  name                     = "tf_sample_vpn"
  nat                      = true
  vpn_profile              = data.smc_href.suite_b_gcm_128.id
}

resource "smc_gateway_node" "tf_sample_central_gateway" {
  from_ref   = smc_vpn.tf_sample_vpn.lk.central_gateway_node
  name       = "tf_sample_central_gateway"
  node_usage = "central"
  gateway    = data.smc_href.internal_gateway["fw1"].id
}

resource "smc_gateway_node" "tf_sample_satellite_gateway2" {
  from_ref   = smc_vpn.tf_sample_vpn.lk.satellite_gateway_node
  name       = "tf_sample_satellite_gateway2"
  node_usage = "satellite"
  gateway    = data.smc_href.internal_gateway["fw2"].id
  child_node = [smc_gateway_node.tf_sample_satellite_gateway3.id]
}

resource "smc_gateway_node" "tf_sample_satellite_gateway3" {
  from_ref   = smc_vpn.tf_sample_vpn.lk.satellite_gateway_node
  name       = "tf_sample_satellite_gateway3"
  node_usage = "satellite"
  gateway    = data.smc_href.internal_gateway["fw3"].id
}

resource "smc_internal_endpoint" "ep_fw1" {
  id = format("%s#%s", smc_single_fw.tf_single_fw["fw1"].lk.internal_gateway,
  "*/internal_endpoint/192.168.101.1")
  enabled = true
  ipsec_vpn = true
}

resource "smc_internal_endpoint" "ep_fw2" {
  id = format("%s#%s", smc_single_fw.tf_single_fw["fw2"].lk.internal_gateway,
  "*/internal_endpoint/192.168.102.1")
  enabled = true
  ipsec_vpn = true
<<<<<<< Updated upstream
  ssl_vpn_tunnel = true
=======
>>>>>>> Stashed changes
}

resource "smc_network" "nw1" {
  name         = "host1"
  ipv4_network = "192.168.104.0/24"
}

resource "smc_vpn_site" "site_fw1" {
  from_ref = format("%s#%s", smc_single_fw.tf_single_fw["fw1"].lk.internal_gateway, "*/vpn_site")
  name     = "site_fw1"

  site_element = [smc_network.nw1.id]
  # gateway = data.smc_href.internal_gateway["fw1"].id

}


